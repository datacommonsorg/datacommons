# --- Shared Global Variables ---
project_id = "your-project-id"
namespace  = "your-namespace"
region     = "us-central1"

# --- Stack Toggles ---
enable_dcp = true
enable_cdc = true

# --- DCP Core ---
dcp_image_url               = "gcr.io/datcom-ci/datacommons-platform:latest"
dcp_service_name            = "dcp-svc"
dcp_service_account_name    = "dcp-sa"
dcp_create_spanner_instance = false
# dcp_spanner_instance_id   = "existing-instance-id" # required when create_spanner_instance=false
dcp_create_spanner_db       = true
dcp_spanner_database_id     = "dcp-db"

# --- DCP Ingestion ---
dcp_deploy_data_ingestion_workflow = false
dcp_create_ingestion_bucket        = true
# dcp_external_ingestion_bucket_name = "existing-bucket-name"
dcp_ingestion_lock_timeout         = 82800

# --- CDC ---
# cdc_dc_api_key = "your-dc-api-key" # https://apikeys.datacommons.org
# cdc_vpc_connector_cidr = "10.13.0.0/28"

# --- Access / Safety ---
make_services_public = false
deletion_protection  = false

# --- Billing (optional) ---
# user_project_override = true
# billing_project_id    = "your-billing-project-id"
